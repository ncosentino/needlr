<Project>
  <!-- NeedlrAutoGenerate defaults to true. Set to false in projects that should not generate a TypeRegistry. -->
  <PropertyGroup Condition="'$(NeedlrAutoGenerate)' == ''">
    <NeedlrAutoGenerate>true</NeedlrAutoGenerate>
  </PropertyGroup>
  <!-- NeedlrNamespacePrefix: semicolon-delimited namespace prefix filter for GenerateTypeRegistry.
       When left empty (the default), the target resolves it to $(RootNamespace) at build time, scoping
       generation to the project's own namespace and sub-namespaces. Override to use a different or
       multiple namespaces. Example: <NeedlrNamespacePrefix>MyApp;MyApp.Plugins</NeedlrNamespacePrefix> -->
  <PropertyGroup Condition="'$(NeedlrNamespacePrefix)' == ''">
    <NeedlrNamespacePrefix></NeedlrNamespacePrefix>
  </PropertyGroup>
  <!-- NeedlrExcludeNamespacePrefix: semicolon-delimited namespace prefixes to EXCLUDE from
       GenerateTypeRegistry. Types whose namespace starts with any of these prefixes are skipped
       even if they match IncludeNamespacePrefixes. Use this when a referenced framework (e.g.,
       Avalonia, MAUI) exposes many public types that Needlr would otherwise try to register.
       Example: <NeedlrExcludeNamespacePrefix>Avalonia;Microsoft.Maui</NeedlrExcludeNamespacePrefix>
       Default: empty (no exclusions). -->
  <PropertyGroup Condition="'$(NeedlrExcludeNamespacePrefix)' == ''">
    <NeedlrExcludeNamespacePrefix></NeedlrExcludeNamespacePrefix>
  </PropertyGroup>
  <!-- NeedlrAutoGenerateAttribute: controls whether NexusLabs.Needlr.Build automatically writes
       the [assembly: GenerateTypeRegistry] attribute file when NeedlrAutoGenerate=true.
       Set to 'false' if you declare the attribute yourself (avoids CS0579 duplicate attribute error).
       Default: not set (auto-generation enabled when NeedlrAutoGenerate=true). -->
</Project>
