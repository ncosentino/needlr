<Project>
  <!--
    Deduplicates NexusLabs.Needlr.Generators if it appears more than once in the Analyzer item
    group (e.g. when referenced both directly and transitively). Runs unconditionally before CoreCompile.
  -->
  <Target Name="DeduplicateNeedlrGeneratorAnalyzers" BeforeTargets="CoreCompile">
    <ItemGroup>
      <_AllNeedlrGeneratorAnalyzers Include="@(Analyzer)"
        Condition="'%(Filename)' == 'NexusLabs.Needlr.Generators'" />
    </ItemGroup>
    <ItemGroup>
      <Analyzer Remove="@(_AllNeedlrGeneratorAnalyzers)" />
    </ItemGroup>
    <ItemGroup>
      <Analyzer Include="@(_AllNeedlrGeneratorAnalyzers->Distinct())" />
    </ItemGroup>
  </Target>

  <!--
    When NeedlrAutoGenerate and NeedlrAutoGenerateAttribute are both 'true', write
    [assembly: GenerateTypeRegistry] to a generated file so the source generator has
    something to act on. Consumers who declare the attribute themselves should set
    NeedlrAutoGenerateAttribute=false to suppress this target (avoids CS0579).
    NeedlrNamespacePrefix controls IncludeNamespacePrefixes; empty means include all types.
    Multiple prefixes are supported as a semicolon-delimited list (e.g. "Foo;Bar").
  -->
  <Target Name="NeedlrWriteTypeRegistryAttributeFile"
          BeforeTargets="CoreCompile"
          Condition="'$(NeedlrAutoGenerate)' == 'true' AND '$(NeedlrAutoGenerateAttribute)' != 'false'">
    <PropertyGroup>
      <_NeedlrAttributeFile>$(IntermediateOutputPath)NeedlrGeneratedTypeRegistry.g.cs</_NeedlrAttributeFile>
    </PropertyGroup>
    <ItemGroup Condition="'$(NeedlrNamespacePrefix)' != ''">
      <_NeedlrNamespacePrefix Include="$(NeedlrNamespacePrefix)" />
    </ItemGroup>
    <PropertyGroup>
      <_NeedlrPrefixList Condition="'$(NeedlrNamespacePrefix)' != ''">@(_NeedlrNamespacePrefix -> '&quot;%(Identity)&quot;', ', ')</_NeedlrPrefixList>
      <_NeedlrAttributeContent Condition="'$(NeedlrNamespacePrefix)' != ''">[assembly: NexusLabs.Needlr.Generators.GenerateTypeRegistry(IncludeNamespacePrefixes = new[] { $(_NeedlrPrefixList) })]</_NeedlrAttributeContent>
      <_NeedlrAttributeContent Condition="'$(NeedlrNamespacePrefix)' == ''">[assembly: NexusLabs.Needlr.Generators.GenerateTypeRegistry()]</_NeedlrAttributeContent>
    </PropertyGroup>
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <WriteLinesToFile
      File="$(_NeedlrAttributeFile)"
      Lines="// &lt;auto-generated /&gt;;$(_NeedlrAttributeContent)"
      Overwrite="true" />
    <ItemGroup>
      <Compile Include="$(_NeedlrAttributeFile)" />
    </ItemGroup>
  </Target>
</Project>
