<Project>
  <!--
    Deduplicates NexusLabs.Needlr.Generators if it appears more than once in the Analyzer item
    group (e.g. when referenced both directly and transitively). Runs unconditionally before CoreCompile.
  -->
  <Target Name="DeduplicateNeedlrGeneratorAnalyzers" BeforeTargets="CoreCompile">
    <ItemGroup>
      <_AllNeedlrGeneratorAnalyzers Include="@(Analyzer)"
        Condition="'%(Filename)' == 'NexusLabs.Needlr.Generators'" />
    </ItemGroup>
    <ItemGroup>
      <Analyzer Remove="@(_AllNeedlrGeneratorAnalyzers)" />
    </ItemGroup>
    <ItemGroup>
      <Analyzer Include="@(_AllNeedlrGeneratorAnalyzers->Distinct())" />
    </ItemGroup>
  </Target>

  <!--
    When NeedlrAutoGenerate and NeedlrAutoGenerateAttribute are both 'true', write
    [assembly: GenerateTypeRegistry] to a generated file so the source generator has
    something to act on. Consumers who declare the attribute themselves should set
    NeedlrAutoGenerateAttribute=false to suppress this target (avoids CS0579).
    NeedlrNamespacePrefix controls IncludeNamespacePrefixes; empty means include all types.
    Multiple prefixes are supported as a semicolon-delimited list (e.g. "Foo;Bar").

    IsRoslynComponent=true and IsAspireHost=true are automatically excluded: Roslyn
    analyzer/generator projects and Aspire AppHost projects are never runtime DI consumers,
    so emitting the attribute there would produce compile errors or be meaningless.
    These properties are set in the project file, so they are available here (in .targets)
    but NOT in .props (evaluated before the project file).
  -->
  <Target Name="NeedlrWriteTypeRegistryAttributeFile"
          BeforeTargets="CoreCompile"
          Condition="'$(NeedlrAutoGenerate)' == 'true'
                 AND '$(NeedlrAutoGenerateAttribute)' != 'false'
                 AND '$(IsRoslynComponent)' != 'true'
                 AND '$(IsAspireHost)' != 'true'">
    <PropertyGroup>
      <!-- Only write the attribute when the Needlr source generator is actually present as an
           Analyzer. This prevents compile errors in projects that import these targets (e.g. via
           Directory.Build.targets) but do not reference NexusLabs.Needlr.Generators. -->
      <_NeedlrHasGenerator>@(Analyzer->AnyHaveMetadataValue('Filename', 'NexusLabs.Needlr.Generators'))</_NeedlrHasGenerator>
      <_NeedlrAttributeFile Condition="'$(_NeedlrHasGenerator)' == 'true'">$(IntermediateOutputPath)NeedlrGeneratedTypeRegistry.g.cs</_NeedlrAttributeFile>
      <!-- Resolve prefix at target execution time (not in .props) so $(RootNamespace) is available.
           If the user has not set NeedlrNamespacePrefix, fall back to $(RootNamespace). -->
      <_NeedlrEffectivePrefix Condition="'$(NeedlrNamespacePrefix)' != ''">$(NeedlrNamespacePrefix)</_NeedlrEffectivePrefix>
      <_NeedlrEffectivePrefix Condition="'$(NeedlrNamespacePrefix)' == ''">$(RootNamespace)</_NeedlrEffectivePrefix>
    </PropertyGroup>
    <ItemGroup Condition="'$(_NeedlrHasGenerator)' == 'true' AND '$(_NeedlrEffectivePrefix)' != ''">
      <_NeedlrNamespacePrefix Include="$(_NeedlrEffectivePrefix)" />
    </ItemGroup>
    <PropertyGroup Condition="'$(_NeedlrHasGenerator)' == 'true'">
      <_NeedlrPrefixList Condition="'$(_NeedlrEffectivePrefix)' != ''">@(_NeedlrNamespacePrefix -> '&quot;%(Identity)&quot;', ', ')</_NeedlrPrefixList>
      <_NeedlrAttributeContent Condition="'$(_NeedlrEffectivePrefix)' != ''">[assembly: NexusLabs.Needlr.Generators.GenerateTypeRegistry(IncludeNamespacePrefixes = new[] { $(_NeedlrPrefixList) })]</_NeedlrAttributeContent>
      <_NeedlrAttributeContent Condition="'$(_NeedlrEffectivePrefix)' == ''">[assembly: NexusLabs.Needlr.Generators.GenerateTypeRegistry()]</_NeedlrAttributeContent>
    </PropertyGroup>
    <MakeDir Directories="$(IntermediateOutputPath)" Condition="'$(_NeedlrHasGenerator)' == 'true'" />
    <WriteLinesToFile
      File="$(_NeedlrAttributeFile)"
      Lines="// &lt;auto-generated /&gt;;$(_NeedlrAttributeContent)"
      Overwrite="true"
      Condition="'$(_NeedlrHasGenerator)' == 'true'" />
    <ItemGroup Condition="'$(_NeedlrHasGenerator)' == 'true'">
      <Compile Include="$(_NeedlrAttributeFile)" />
    </ItemGroup>
  </Target>
</Project>
