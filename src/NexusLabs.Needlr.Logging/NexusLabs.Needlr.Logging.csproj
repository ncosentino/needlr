<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Cancellation-aware source-generated logging methods for Needlr. Provides the [NeedlrLoggerMessage] attribute and a configurable policy for suppressing or demoting logs caused by cancellation.</Description>
    <PackageTags>needlr;logging;source-generator;loggermessage;cancellation;di;dependency-injection</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <!-- Run the logging generator and analyzer during this project's own build, and pack them as analyzer assets. -->
  <ItemGroup>
    <ProjectReference Include="..\NexusLabs.Needlr.Logging.Generators\NexusLabs.Needlr.Logging.Generators.csproj"
                      PrivateAssets="all"
                      ReferenceOutputAssembly="false"
                      OutputItemType="Analyzer" />
    <ProjectReference Include="..\NexusLabs.Needlr.Logging.Analyzers\NexusLabs.Needlr.Logging.Analyzers.csproj"
                      PrivateAssets="all"
                      ReferenceOutputAssembly="false"
                      OutputItemType="Analyzer" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\NexusLabs.Needlr.Logging.Generators\bin\$(Configuration)\netstandard2.0\NexusLabs.Needlr.Logging.Generators.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
    <None Include="..\NexusLabs.Needlr.Logging.Analyzers\bin\$(Configuration)\netstandard2.0\NexusLabs.Needlr.Logging.Analyzers.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="NexusLabs.Needlr.Logging.Tests" />
  </ItemGroup>

</Project>
