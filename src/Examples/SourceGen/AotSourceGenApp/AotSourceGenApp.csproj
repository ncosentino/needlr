<Project Sdk="Microsoft.NET.Sdk.Web">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<!-- NativeAOT host -->
		<PublishAot>true</PublishAot>
		<IsAotCompatible>true</IsAotCompatible>
		<EnableRequestDelegateGenerator>true</EnableRequestDelegateGenerator>

		<!-- Trimming: host is the proving ground -->
		<PublishTrimmed>true</PublishTrimmed>
		<TrimMode>full</TrimMode>

		<!-- Make reflection usage fail loudly -->
		<IlcDisableReflection>true</IlcDisableReflection>

		<!-- Optional: smaller/faster (tradeoffs) -->
		<InvariantGlobalization>true</InvariantGlobalization>
		<IlcGenerateStackTraceData>false</IlcGenerateStackTraceData>

		<!-- Analyze + enforce -->
		<EnableTrimAnalyzer>true</EnableTrimAnalyzer>
		<EnableAotAnalyzer>true</EnableAotAnalyzer>
		<TrimmerSingleWarn>false</TrimmerSingleWarn>
		<SuppressTrimAnalysisWarnings>false</SuppressTrimAnalysisWarnings>
		<WarningsAsErrors>$(WarningsAsErrors);IL2026;IL2060;IL2072;IL2075;IL2091</WarningsAsErrors>

		<!-- Override: this example intentionally consolidates both namespaces into the host's
		     TypeRegistry rather than using a separate plugin registry (simpler, single source of truth).
		     AotSourceGenPlugin suppresses its own auto-generation to avoid double-registration. -->
		<NeedlrNamespacePrefix>AotSourceGen;AotSourceGenPlugin</NeedlrNamespacePrefix>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\..\NexusLabs.Needlr.AspNet\NexusLabs.Needlr.AspNet.csproj" />
		<ProjectReference Include="..\..\..\NexusLabs.Needlr.Injection.SourceGen\NexusLabs.Needlr.Injection.SourceGen.csproj" />
		<ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators\NexusLabs.Needlr.Generators.csproj"
						  OutputItemType="Analyzer"
						  ReferenceOutputAssembly="false" />
		<ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators.Attributes\NexusLabs.Needlr.Generators.Attributes.csproj" />
		<ProjectReference Include="..\AotSourceGenPlugin\AotSourceGenPlugin.csproj" />
	</ItemGroup>
</Project>