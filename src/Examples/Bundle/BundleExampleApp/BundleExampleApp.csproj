<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Override: this app has no injectable types of its own. All services live in
         BundleExamplePlugin (a separate project/namespace). Without this override the
         generator would scope to "BundleExampleApp" and produce an empty registry,
         causing the bundle to silently fall back to reflection instead of source-gen. -->
    <NeedlrNamespacePrefix>BundleExamplePlugin</NeedlrNamespacePrefix>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\NexusLabs.Needlr.Injection.Bundle\NexusLabs.Needlr.Injection.Bundle.csproj" />
    <ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators\NexusLabs.Needlr.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators.Attributes\NexusLabs.Needlr.Generators.Attributes.csproj" />
    <ProjectReference Include="..\BundleExamplePlugin\BundleExamplePlugin.csproj" />
  </ItemGroup>

</Project>
