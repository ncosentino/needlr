<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- Optional optimization: this project has no injectable types of its own. Without this,
         the generator still runs but produces an empty TypeRegistry. No errors or warnings occur
         either way — uncomment to skip the unnecessary codegen for this assembly.
    <NeedlrAutoGenerateAttribute>false</NeedlrAutoGenerateAttribute>
    -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators.Attributes\NexusLabs.Needlr.Generators.Attributes.csproj" />
    <ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators\NexusLabs.Needlr.Generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\MultiProjectApp.Features.Notifications\MultiProjectApp.Features.Notifications.csproj" />
    <ProjectReference Include="..\MultiProjectApp.Features.Reporting\MultiProjectApp.Features.Reporting.csproj" />
  </ItemGroup>

</Project>
