<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!--
      This project intentionally has NO injectable types and references NO Needlr injection packages.
      It carries [assembly: GenerateTypeRegistry] (NeedlrAutoGenerate=true is inherited from
      Directory.Build.props) but has nothing to register. The generator emits a minimal,
      injection-free TypeRegistry for it: it depends only on the attributes package, so the project
      compiles cleanly without referencing IServiceCollection / IServiceCatalog, and it can be
      referenced by an aggregator without causing a CS0234 force-load failure.
    -->
  </PropertyGroup>

  <ItemGroup>
    <!-- Generator added as Analyzer only — no injection packages. -->
    <!-- Generators.Attributes provides GenerateTypeRegistry; would come transitively via NexusLabs.Needlr.Build in production. -->
    <ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators.Attributes\NexusLabs.Needlr.Generators.Attributes.csproj" />
    <ProjectReference Include="..\..\..\NexusLabs.Needlr.Generators\NexusLabs.Needlr.Generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
